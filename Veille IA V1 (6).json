    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Séparer la synthèse des articles\nconst synthese = items.find(i => i.json.text)?.json.text || \"Synthèse non disponible.\";\nconst articles = items.filter(i => i.json.titre);\n\n// Statistiques\nconst scores = articles.map(a => a.json.pertinence_score || 0);\nconst scoreMoyen = (scores.reduce((a, b) => a + b, 0) / scores.length).toFixed(1);\n\nconst categories = {};\narticles.forEach(a => {\n  const cat = a.json.categorie || \"Autre\";\n  categories[cat] = (categories[cat] || 0) + 1;\n});\n\nconst statsCategories = Object.entries(categories)\n  .sort((a, b) => b[1] - a[1])\n  .map(([cat, count]) => `${cat} : ${count} article${count > 1 ? 's' : ''}`)\n  .join(\" | \");\n\n// Icônes par catégorie\nconst icones = {\n  \"IA\": \"🤖\",\n  \"Tech\": \"💻\",\n  \"Jeux vidéo\": \"🎮\",\n  \"Cinéma\": \"🎬\",\n  \"Robotique\": \"🦾\",\n  \"Cybersécurité\": \"🔐\",\n  \"Business\": \"📈\",\n  \"Autre\": \"📌\"\n};\n\nconst iconeImportance = {\n  \"Critique\": \"🔥\",\n  \"Haute\": \"⭐\",\n  \"Moyenne\": \"🟡\",\n  \"Faible\": \"⚪\"\n};\n\n// Construction du rapport HTML\nlet articlesHTML = \"\";\narticles.forEach((item, index) => {\n  const a = item.json;\n  const icone = icones[a.categorie] || \"📌\";\n  const imp = iconeImportance[a.importance] || \"🟡\";\n  const pointsCles = (a.points_cles || []).map(p => `<li>${p}</li>`).join(\"\");\n\n  articlesHTML += `\n    <div style=\"border-left: 3px solid #7c3aed; padding: 12px 16px; margin-bottom: 20px; background: #f9f8ff;\">\n      <div style=\"font-size: 11px; color: #888; font-family: monospace; margin-bottom: 4px;\">\n        ${icone} ${a.categorie} &nbsp;·&nbsp; ${imp} ${a.importance} &nbsp;·&nbsp; ⏱️ ${a.lecture_estimee} &nbsp;·&nbsp; ⭐ ${a.pertinence_score}/10\n      </div>\n      <div style=\"font-weight: 600; font-size: 15px; color: #1a1a2e; margin-bottom: 6px;\">\n        <a href=\"${a.Url || a.url || a.URL || '#'}\" style=\"color: #7c3aed; text-decoration: none;\">${a.titre}</a>\n      </div>\n      <div style=\"font-size: 13px; color: #444; margin-bottom: 8px;\">${a.resume}</div>\n      <ul style=\"font-size: 12px; color: #555; padding-left: 18px; margin: 0;\">\n        ${pointsCles}\n      </ul>\n    </div>\n  `;\n});\n\nconst html = `\n<!DOCTYPE html>\n<html lang=\"fr\">\n<head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"></head>\n<body style=\"font-family: 'Segoe UI', sans-serif; max-width: 680px; margin: 0 auto; padding: 24px; color: #1a1a2e; background: #ffffff;\">\n\n  <div style=\"text-align: center; padding: 24px 0 16px; border-bottom: 2px solid #7c3aed; margin-bottom: 24px;\">\n    <div style=\"font-size: 11px; color: #888; font-family: monospace; letter-spacing: 0.1em; text-transform: uppercase;\">Veille quotidienne</div>\n    <div style=\"font-size: 28px; font-weight: 700; color: #7c3aed; margin: 6px 0;\">📡 Veille IA & Tech</div>\n    <div style=\"font-size: 12px; color: #999;\">${new Date().toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</div>\n  </div>\n\n  <div style=\"background: #1a1a2e; color: #e8e6f0; border-radius: 10px; padding: 20px 24px; margin-bottom: 28px;\">\n    <div style=\"font-size: 11px; color: #a78bfa; font-family: monospace; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10px;\">🧠 Synthèse du jour</div>\n    <div style=\"font-size: 14px; line-height: 1.8; color: #d1d5db;\">${synthese}</div>\n  </div>\n\n  <div style=\"background: #f5f4f0; border-radius: 8px; padding: 12px 16px; margin-bottom: 28px; font-size: 12px; color: #555; font-family: monospace;\">\n    📊 ${articles.length} articles analysés &nbsp;·&nbsp; Score moyen : ${scoreMoyen}/10 &nbsp;·&nbsp; ${statsCategories}\n  </div>\n\n  <div style=\"font-size: 11px; color: #7c3aed; font-family: monospace; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 16px;\">🔥 Top ${articles.length} du jour</div>\n\n  ${articlesHTML}\n\n  <div style=\"text-align: center; padding: 20px 0; border-top: 1px solid #e5e7eb; margin-top: 24px; font-size: 11px; color: #aaa; font-family: monospace;\">\n    Généré automatiquement · Workflow n8n · Gemini Flash\n  </div>\n\n</body>\n</html>\n`;\n\nreturn [{ json: { html, synthese, nb_articles: articles.length, score_moyen: scoreMoyen } }];"
      },
