    {
      "parameters": {
        "jsCode": "const articles = $input.all();\n\nlet contenu = \"\";\n\narticles.forEach((item, index) => {\n  const a = item.json;\n\n  contenu += `\nArticle ${index + 1}\n\nTitre : ${a.titre}\n\nCatégorie : ${a.categorie}\n\nPertinence : ${a.pertinence_score}/10\n\nRésumé :\n${a.resume}\n\nPoints clés :\n- ${a.points_cles.join(\"\\n- \")}\n\n-------------------------\n\n`;\n});\n\nreturn [\n  {\n    json: {\n      articles: contenu\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2352,
        112
      ],
      "id": "9f6619af-eb86-4ddc-90e7-021518ccdce0",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Voici les principaux articles du jour.\n\n{{ $json[\"articles\"] }}\n\nRédige une synthèse.",
        "hasOutputParser": true,
        "messages": {
          "messageValues": [
            {
              "message": "=Tu es rédacteur en chef d'une newsletter de veille technologique.\n\nÀ partir de plusieurs articles déjà résumés, rédige une synthèse professionnelle.\n\nLe texte doit :\n- faire entre 120 et 180 mots\n- être fluide\n- mettre en avant les tendances importantes\n- ne pas répéter chaque article\n- conclure par une phrase résumant la journée\n\nRéponds uniquement avec le texte."
            }
          ]
        },
        "batching": {}
