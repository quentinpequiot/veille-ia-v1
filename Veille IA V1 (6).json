    {
      "parameters": {
        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  let rawText = item.json.text || item.json.output || \"\";\n  \n  // Retirer les balises markdown ```json ... ```\n  rawText = rawText.replace(/```json\\s*/g, \"\").replace(/```\\s*/g, \"\").trim();\n  \n  // Retirer les virgules traînantes (trailing commas) avant ] ou }\n  rawText = rawText.replace(/,\\s*([}\\]])/g, \"$1\");\n  \n  let parsed;\n  try {\n    parsed = JSON.parse(rawText);\n  } catch (e) {\n    parsed = {\n      titre: \"ERREUR PARSING\",\n      resume: rawText.substring(0, 200),\n      points_cles: [],\n      categorie: \"Autre\",\n      pertinence_score: 0,\n      raison_score: \"Erreur de parsing JSON : \" + e.message\n    };\n  }\n  \n  items.push({ json: parsed });\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
